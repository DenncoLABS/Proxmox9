#!/usr/bin/env bash
set -euo pipefail

TARGET_DIR="/usr/share/novnc/app/dennco-clipboard"
INDEX_FILE="/usr/share/novnc/vnc.html"
BACKUP_FILE="/usr/share/novnc/vnc.html.dennco-clipboard.bak"

if [[ -f "$BACKUP_FILE" && -f "$INDEX_FILE" ]]; then
  cp "$BACKUP_FILE" "$INDEX_FILE"
  rm -f "$BACKUP_FILE"
elif [[ -f "$INDEX_FILE" ]]; then
  sed -i '/dennco-clipboard\/novnc-clipboard-panel.css/d' "$INDEX_FILE" || true
  sed -i '/dennco-clipboard\/novnc-clipboard-panel.js/d' "$INDEX_FILE" || true
fi

rm -rf "$TARGET_DIR"

echo "Dennco noVNC clipboard panel removed."
