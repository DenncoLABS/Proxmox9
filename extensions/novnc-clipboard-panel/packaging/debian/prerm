#!/usr/bin/env bash
set -euo pipefail

STAMP="dennco-clipboard-panel"
MARK_START="DENNCO_NOVNC_CLIPBOARD_PANEL_LOADER"
MARK_END="END_DENNCO_NOVNC_CLIPBOARD_PANEL_LOADER"

LOADER_FILES=(
  "/usr/share/novnc-pve/app.js"
  "/usr/share/novnc-pve/app/ui.js"
  "/usr/share/novnc/app.js"
  "/usr/share/novnc/app/ui.js"
  "/usr/share/novnc/vnc.html"
)

ASSET_DIRS=(
  "/usr/share/novnc-pve/dennco-clipboard"
  "/usr/share/novnc-pve/app/dennco-clipboard"
  "/usr/share/novnc/dennco-clipboard"
  "/usr/share/novnc/app/dennco-clipboard"
)

for file in "${LOADER_FILES[@]}"; do
  if [[ -f "$file" ]]; then
    sed -i "/$MARK_START/,/$MARK_END/d" "$file" || true
  fi

done

for dir in "${ASSET_DIRS[@]}"; do
  rm -rf "$dir"
done

systemctl reload pveproxy 2>/dev/null || true

echo "Dennco noVNC clipboard panel removed."
